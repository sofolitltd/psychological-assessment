{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/test/**",
        "destination": "/index.html"
      },
      {
        "source": "/upcoming/**",
        "destination": "/index.html"
      },
      {
        "source": "/about/**",
        "destination": "/index.html"
      }
    ]
  }
}
